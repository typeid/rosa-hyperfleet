# CI build-root image for rosa-hyperfleet PR checks.
# Used by ci-operator via build_root.project_image.dockerfile_path.
# Tools are layer-cached — installs only re-run when this file changes.

FROM registry.access.redhat.com/ubi9/ubi:latest

# Optionally install a proxy CA cert at build time (e.g. egress proxy environments).
# Pass the PEM content via: --build-arg PROXY_CA_CERT="$(cat /path/to/ca.crt)"
ARG PROXY_CA_CERT=""
RUN if [ -n "${PROXY_CA_CERT}" ]; then \
        echo "${PROXY_CA_CERT}" > /etc/pki/ca-trust/source/anchors/proxy-ca.crt && \
        update-ca-trust; \
    fi

# Tool versions
ARG TERRAFORM_VERSION=1.14.3
ARG HELM_VERSION=v3.16.0
ARG UV_VERSION=0.6.0
ARG AWS_CLI_VERSION=2.34.19
ARG PRETTIER_VERSION=3.8.1
ARG YQ_VERSION=v4.44.3
ARG K6_VERSION=0.55.0
ARG PROMETHEUS_VERSION=3.4.1
ARG LEAKTK_VERSION=0.3.3

# Global curl retry and timeout settings for improved download reliability
ARG CURL_RETRY=3
ARG CURL_RETRY_DELAY=2
ARG CURL_MAX_TIME=300

# System packages
RUN dnf install -y \
        git \
        make \
        jq \
        unzip \
        xz \
        python3-pip \
        findutils \
        gnupg2 \
        openssl \
        golang \
        nodejs \
        npm \
    && dnf clean all

# Prettier (for markdown doc checks)
RUN npm install -g prettier@${PRETTIER_VERSION}

# Terraform (GPG-verified)
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  arch="amd64" ;; \
        aarch64) arch="arm64" ;; \
    esac && \
    TF_PACKAGE="terraform_${TERRAFORM_VERSION}_linux_${arch}.zip" && \
    TF_BASE_URL="https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${TF_BASE_URL}/${TF_PACKAGE}" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${TF_BASE_URL}/terraform_${TERRAFORM_VERSION}_SHA256SUMS" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${TF_BASE_URL}/terraform_${TERRAFORM_VERSION}_SHA256SUMS.sig" && \
    ( if [ -n "${PROXY_CA_CERT}" ]; then \
        curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0xC874011F0AB405110D02105534365D9472D7468F" | gpg --batch --import || \
        curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSL "https://keys.openpgp.org/vks/v1/by-fingerprint/C874011F0AB405110D02105534365D9472D7468F" | gpg --batch --import || \
        curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSL "https://pgp.mit.edu/pks/lookup?op=get&search=0xC874011F0AB405110D02105534365D9472D7468F" | gpg --batch --import; \
      else \
        gpg --batch --keyserver keyserver.ubuntu.com --recv-keys C874011F0AB405110D02105534365D9472D7468F || \
        gpg --batch --keyserver keys.openpgp.org --recv-keys C874011F0AB405110D02105534365D9472D7468F || \
        gpg --batch --keyserver pgp.mit.edu --recv-keys C874011F0AB405110D02105534365D9472D7468F; \
      fi ) && \
    gpg --batch --verify "terraform_${TERRAFORM_VERSION}_SHA256SUMS.sig" \
        "terraform_${TERRAFORM_VERSION}_SHA256SUMS" && \
    grep "${TF_PACKAGE}" "terraform_${TERRAFORM_VERSION}_SHA256SUMS" | sha256sum -c - && \
    unzip -qo "${TF_PACKAGE}" -d /usr/local/bin && \
    chmod +x /usr/local/bin/terraform && \
    rm -f "${TF_PACKAGE}" "terraform_${TERRAFORM_VERSION}_SHA256SUMS" \
        "terraform_${TERRAFORM_VERSION}_SHA256SUMS.sig"

# Helm 3 (pinned release tag; get-helm-3 verifies checksums by default)
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSL "https://raw.githubusercontent.com/helm/helm/${HELM_VERSION}/scripts/get-helm-3" \
    | DESIRED_VERSION="${HELM_VERSION}" VERIFY_CHECKSUM=true bash

# uv (Python package manager - pinned version, installer verifies binary checksum)
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSL "https://astral.sh/uv/${UV_VERSION}/install.sh" -o /tmp/uv-install.sh && \
    UV_UNMANAGED_INSTALL=/usr/local/bin sh /tmp/uv-install.sh && \
    rm /tmp/uv-install.sh && \
    uv --version

# AWS CLI v2
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  AWS_ARCH="x86_64" ;; \
        aarch64) AWS_ARCH="aarch64" ;; \
    esac && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-${AWS_ARCH}-${AWS_CLI_VERSION}.zip" -o "awscliv2.zip" && \
    unzip -qo awscliv2.zip && \
    ./aws/install && \
    rm -rf awscliv2.zip ./aws && \
    aws --version

# yq (YAML processor)
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  YQ_ARCH="amd64" ;; \
        aarch64) YQ_ARCH="arm64" ;; \
    esac && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_${YQ_ARCH}" -o /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq && \
    yq --version

# k6 (load testing, checksum-verified)
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  K6_ARCH="amd64" ;; \
        aarch64) K6_ARCH="arm64" ;; \
    esac && \
    K6_BASE="https://github.com/grafana/k6/releases/download/v${K6_VERSION}" && \
    K6_TAR="k6-v${K6_VERSION}-linux-${K6_ARCH}.tar.gz" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${K6_BASE}/${K6_TAR}" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${K6_BASE}/k6-v${K6_VERSION}-checksums.txt" && \
    grep "${K6_TAR}" "k6-v${K6_VERSION}-checksums.txt" | sha256sum -c - && \
    tar -xzf "${K6_TAR}" --strip-components=1 -C /usr/local/bin "k6-v${K6_VERSION}-linux-${K6_ARCH}/k6" && \
    chmod +x /usr/local/bin/k6 && \
    rm -f "${K6_TAR}" "k6-v${K6_VERSION}-checksums.txt" && \
    k6 version

# promtool (Prometheus rule validation and testing)
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  PROM_ARCH="amd64" ;; \
        aarch64) PROM_ARCH="arm64" ;; \
    esac && \
    PROM_TAR="prometheus-${PROMETHEUS_VERSION}.linux-${PROM_ARCH}.tar.gz" && \
    PROM_BASE="https://github.com/prometheus/prometheus/releases/download/v${PROMETHEUS_VERSION}" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${PROM_BASE}/${PROM_TAR}" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${PROM_BASE}/sha256sums.txt" && \
    grep "${PROM_TAR}" sha256sums.txt | sha256sum -c - && \
    tar -xzf "${PROM_TAR}" --strip-components=1 -C /usr/local/bin \
        "prometheus-${PROMETHEUS_VERSION}.linux-${PROM_ARCH}/promtool" && \
    chmod +x /usr/local/bin/promtool && \
    rm -f "${PROM_TAR}" sha256sums.txt && \
    promtool --version

# leaktk (secret leak scanner, checksum-verified)
ARG CURL_RETRY
ARG CURL_RETRY_DELAY
ARG CURL_MAX_TIME
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  LEAKTK_ARCH="x86_64" ;; \
        aarch64) LEAKTK_ARCH="arm64" ;; \
    esac && \
    LEAKTK_TAR="leaktk-${LEAKTK_VERSION}-linux-${LEAKTK_ARCH}.tar.xz" && \
    LEAKTK_CHECKSUMS="leaktk_${LEAKTK_VERSION}_checksums.txt" && \
    LEAKTK_BASE="https://github.com/leaktk/leaktk/releases/download/v${LEAKTK_VERSION}" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${LEAKTK_BASE}/${LEAKTK_TAR}" && \
    curl --retry ${CURL_RETRY} --retry-delay ${CURL_RETRY_DELAY} --max-time ${CURL_MAX_TIME} -fsSLO "${LEAKTK_BASE}/${LEAKTK_CHECKSUMS}" && \
    grep "${LEAKTK_TAR}" "${LEAKTK_CHECKSUMS}" | sha256sum -c - && \
    tar -xJf "${LEAKTK_TAR}" -C /usr/local/bin leaktk && \
    chmod +x /usr/local/bin/leaktk && \
    rm -f "${LEAKTK_TAR}" "${LEAKTK_CHECKSUMS}" && \
    leaktk version

# Pre-create cache directories writable by any UID (OpenShift runs as random UID)
RUN mkdir -p /tmp/.uv-cache /tmp/.uv-python /tmp/.terraform.d /tmp/.cache/go-build /tmp/gopath && \
    chmod -R 777 /tmp/.uv-cache /tmp/.uv-python /tmp/.terraform.d /tmp/.cache/go-build /tmp/gopath

ENV UV_CACHE_DIR=/tmp/.uv-cache
ENV UV_PYTHON_INSTALL_DIR=/tmp/.uv-python
ENV UV_NO_PROGRESS=true
ENV GOPATH=/tmp/gopath
ENV GOCACHE=/tmp/.cache/go-build

# Python packages (awscurl for API Gateway testing, pyyaml for CI override parsing)
RUN if [ -n "${PROXY_CA_CERT}" ]; then \
        uv pip install --system --native-tls awscurl pyyaml; \
    else \
        uv pip install --system awscurl pyyaml; \
    fi
