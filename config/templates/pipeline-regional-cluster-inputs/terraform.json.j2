{
  "_generated": "DO NOT EDIT - Generated by render.py",
  "app_code": "{{ terraform_tags.app_code }}",
  "service_phase": "{{ terraform_tags.service_phase }}",
  "cost_center": "{{ terraform_tags.cost_center }}",
  "environment": "{{ environment }}",
  "account_id": "{{ account_id }}",
  "region": "{{ aws_region }}",
  "deployment_name": "{{ deployment_name }}",
  "alias": "regional-{{ aws_region }}",
  "enable_bastion": {{ regional_cluster.enable_bastion | default(false) | tojson }},
  "enable_cloudtrail": {{ regional_cluster.enable_cloudtrail | default(true) | tojson }},
  "enable_pagerduty": {{ observability.pagerduty.enabled | default(false) | tojson }},
  "pagerduty_escalation_policy_id": {{ observability.pagerduty.escalation_policy_id | default('') | tojson }},
  "enable_api_custom_domain": {{ regional_cluster.enable_api_custom_domain | default(false) | tojson }},
  "zone_shard_count": {{ regional_cluster.zone_shard_count | default(1) | tojson }},
  "enable_sns_alerting": {{ observability.sns_alerting.enabled | default(false) | tojson }},
  "regional_id": "{% if eph_prefix %}{{ eph_prefix }}-regional{% else %}regional{% endif %}",
  "eph_prefix": "{{ eph_prefix | default('') }}",
  "hyperfleet_db_instance_class": {{ regional_cluster.hyperfleet_db_instance_class | default('db.r6g.large') | tojson }},
  "hyperfleet_db_deletion_protection": {{ regional_cluster.hyperfleet_db_deletion_protection | default(true) | tojson }},
  "hyperfleet_db_skip_final_snapshot": {{ regional_cluster.hyperfleet_db_skip_final_snapshot | default(false) | tojson }},
  "hyperfleet_db_performance_insights_enabled": {{ regional_cluster.hyperfleet_db_performance_insights_enabled | default(true) | tojson }},
  "hyperfleet_db_monitoring_interval": {{ regional_cluster.hyperfleet_db_monitoring_interval | default(60) | tojson }}
{%- set _mc_info = [] %}
{%- for mc in management_clusters if mc.account_id is defined %}
{%- set _ = _mc_info.append({"id": mc.management_id, "account_id": mc.account_id}) %}
{%- endfor %}
{%- if _mc_info %},
  "management_clusters_info": {{ _mc_info | tojson }}{% endif %}{% if delete %},
  "delete": true{% endif %}
}
