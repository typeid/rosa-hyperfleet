# GENERATED FILE - DO NOT EDIT MANUALLY
#
# Generated by render.py
# Cluster Type: {{ cluster_type }}
# Environment: {{ environment }}
# Region: {{ aws_region }}
{%- set pinned = git.revision if (git.revision and git.revision != "main") else "" %}
# Config Revision: {{ pinned[:8] if pinned else "metadata.annotations.git_revision" }}

apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: root-applicationset
  namespace: argocd
spec:
  goTemplate: true
  generators:
  - matrix:
      generators:
      - clusters:
          selector:
            matchLabels:
              argocd.argoproj.io/secret-type: cluster
      - git:
          directories:
          - path: argocd/config/{{ '{{ .metadata.labels.cluster_type }}' }}/*
          - path: argocd/config/shared/*
          repoURL: '{{ '{{ .metadata.annotations.git_repo }}' }}'
          revision: '{% if pinned %}{{ pinned }}{% else %}{{ "{{ .metadata.annotations.git_revision }}" }}{% endif %}'
  template:
    metadata:
      name: '{{ '{{ .path.basename }}' }}'
      labels:
        cluster_type: '{{ '{{ .metadata.labels.cluster_type }}' }}'
        environment: '{{ '{{ .metadata.labels.environment }}' }}'
        region_deployment: '{{ '{{ .metadata.labels.region_deployment }}' }}'
        aws_region: '{{ '{{ .metadata.labels.aws_region }}' }}'
    spec:
      project: default
      destination:
        namespace: '{{ '{{ .path.basename }}' }}'
        server: '{{ '{{ .server }}' }}'
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        retry:
          limit: -1
          backoff:
            duration: 5s
            factor: 2
            maxDuration: 1m
        syncOptions:
        - ServerSideApply=true
        - CreateNamespace=true
      sources:
      - helm:
          valueFiles:
          - values.yaml
          - $values/deploy/{{ '{{ .metadata.labels.environment }}' }}/{{ '{{ .metadata.labels.region_deployment }}' }}/argocd-values-{{ '{{ .metadata.labels.cluster_type }}' }}.yaml
          valuesObject:
            global:
              cluster_type: '{{ '{{ .metadata.labels.cluster_type }}' }}'
              environment: '{{ '{{ .metadata.labels.environment }}' }}'
              aws_region: '{{ '{{ .metadata.labels.aws_region }}' }}'
              cluster_name: '{{ '{{ .metadata.labels.cluster_name }}' }}'
              aws_account_id: '{{ '{{ .metadata.annotations.aws_account_id }}' }}'
{% if cluster_type == 'management-cluster' %}
              rc_aws_account_id: '{{ '{{ .metadata.annotations.rc_aws_account_id }}' }}'
{% endif %}
              management_clusters: '{{ '{{ .metadata.annotations.management_clusters }}' }}'
              rhobs_api_url: '{{ '{{ .metadata.annotations.rhobs_api_url }}' }}'
              dns_zone_operator_role_arn: '{{ '{{ .metadata.annotations.dns_zone_operator_role_arn }}' }}'
              git_revision: '{% if pinned %}{{ pinned }}{% else %}{{ "{{ .metadata.annotations.git_revision }}" }}{% endif %}'
            platformApi:
              targetGroup:
                arn: '{{ '{{ .metadata.annotations.api_target_group_arn }}' }}'
              app:
                args:
                  dynamodbRegion: '{{ '{{ .metadata.annotations.dynamodb_region }}' }}'
                  dynamodbPrefix: '{{ '{{ .metadata.annotations.dynamodb_prefix }}' }}'
                  oidcIssuerBaseURL: 'https://{{ '{{ .metadata.annotations.oidc_cloudfront_domain }}' }}'
              zoa:
                tableName: '{{ '{{ .metadata.annotations.zoa_table_name }}' }}'
                auditTableName: '{{ '{{ .metadata.annotations.zoa_audit_table_name }}' }}'
                bucketName: '{{ '{{ .metadata.annotations.zoa_bucket_name }}' }}'
            # Thanos Operator values (keys must match chart's values.yaml structure)
            thanos:
              kmsKeyArn: '{{ '{{ .metadata.annotations.thanos_kms_key_arn }}' }}'
              targetGroup:
                arn: '{{ '{{ .metadata.annotations.thanos_target_group_arn }}' }}'
              queryTargetGroup:
                arn: '{{ '{{ .metadata.annotations.thanos_query_target_group_arn }}' }}'
            # Loki platform values (keys must match chart's values.yaml structure)
            platform:
              kmsKeyArn: '{{ '{{ .metadata.annotations.loki_kms_key_arn }}' }}'
              distributorTargetGroup:
                arn: '{{ '{{ .metadata.annotations.loki_distributor_target_group_arn }}' }}'
              queryFrontendTargetGroup:
                arn: '{{ '{{ .metadata.annotations.loki_query_frontend_target_group_arn }}' }}'
            # Loki subchart runtime values (bucket names, region, SSE-KMS)
            loki:
              loki:
                storage:
                  s3:
                    region: '{{ '{{ .metadata.labels.aws_region }}' }}'
                    sse:
                      type: SSE-KMS
                      kms_key_id: '{{ '{{ .metadata.annotations.loki_kms_key_arn }}' }}'
                  bucketNames:
                    chunks: '{{ '{{ .metadata.labels.cluster_name }}' }}-loki-logs-{{ '{{ .metadata.annotations.aws_account_id }}' }}'
                    ruler: '{{ '{{ .metadata.labels.cluster_name }}' }}-loki-logs-{{ '{{ .metadata.annotations.aws_account_id }}' }}'
        path: '{{ '{{ .path.path }}' }}'
        repoURL: '{{ '{{ .metadata.annotations.git_repo }}' }}'
        targetRevision: '{% if pinned %}{{ pinned }}{% else %}{{ "{{ .metadata.annotations.git_revision }}" }}{% endif %}'
      - repoURL: '{{ "{{ .metadata.annotations.git_repo | replace \"github.com\" \"github.com:443\" }}" }}'
        targetRevision: '{{ '{{ .metadata.annotations.git_revision }}' }}'
        ref: values
