{
  "title": "Platform Services",
  "uid": "platform-services",
  "description": "CloudWatch metrics for shared platform services: ACM certificate health.",
  "tags": ["aws", "cloudwatch", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [

    {
      "id": 14,
      "type": "row",
      "title": "ACM – Certificate Expiry",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 15,
      "type": "stat",
      "title": "Days to Expiry",
      "description": "ACM publishes this metric once per day. Widen the time range to 7d or 30d if no data appears. Alert threshold: yellow at 30 days, red at 7 days.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "min(aws_certificatemanager_days_to_expiry_minimum)",
          "legendFormat": "Days to Expiry"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 72 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 7, "color": "yellow" },
              { "value": 30, "color": "green" }
            ]
          }
        }
      }
    },

    {
      "id": 16,
      "type": "timeseries",
      "title": "Certificate Days to Expiry – Trend",
      "description": "Should decrease by 1 per day. A flat line means ACM stopped publishing — check certificate status in the console.",
      "gridPos": { "x": 6, "y": 1, "w": 18, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_certificatemanager_days_to_expiry_minimum",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 7, "color": "yellow" },
              { "value": 30, "color": "green" }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    }

  ],
  "annotations": { "list": [] },
  "links": []
}
